<!-- Contact Form Section -->
<section id="contact-form" class="py-20 px-6 lg:px-12">
  <div class="container mx-auto bg-[#3B82F6] rounded-3xl overflow-hidden shadow-2xl">
    <div class="flex flex-col lg:flex-row">
      <div
        class="w-full lg:w-1/2 p-8 lg:p-16 bg-[#22C55E] text-white relative flex flex-col justify-center items-center text-center lg:text-left">
        <div class="absolute inset-0">
          <svg class="w-full h-full text-[#4ADE80] opacity-40 absolute inset-0" viewBox="0 0 500 500"
               preserveAspectRatio="none">
            <path d="M0,100 C150,200 350,0 500,100 L500,00 L0,0 Z" fill="currentColor"></path>
          </svg>
        </div>
        <div class="relative z-10">
          <h2 class="text-4xl md:text-5xl font-extrabold mb-4">{{#if section.title}}{{section.title}}{{else}}{{#if t.contact.title}}{{t.contact.title}}{{else}}HELLO{{/if}}{{/if}}</h2>
          <p class="text-sm md:text-base mb-8 max-w-sm mx-auto lg:mx-0">
            {{#if section.subtitle}}{{section.subtitle}}{{else}}{{#if t.contact.subtitle}}{{t.contact.subtitle}}{{else}}Our team of experts is here to help find the solution that fits your students' needs.{{/if}}{{/if}}
          </p>
          <img src="{{#if section.imageUrl}}{{section.imageUrl}}{{else}}/images/pngaaa.com-2430743%20(1)%201.png{{/if}}" alt="LEGO model"
               class="rounded-xl mt-8 mx-auto lg:mx-0">
        </div>
      </div>
      <div class="w-full lg:w-1/2 p-8 lg:p-16 bg-white flex flex-col justify-center">
        <h3 class="text-2xl font-bold text-gray-800 mb-2">{{#if t.contact.heading}}{{t.contact.heading}}{{else}}CONTACT US{{/if}}</h3>
        <p class="text-sm text-gray-600 mb-6">{{#if t.contact.interested}}{{t.contact.interested}}{{else}}I'm interested in becoming a*{{/if}}</p>

        <form action="/email/send" method="post" class="space-y-4">

          <div class="flex items-center space-x-4">
            <label class="flex items-center space-x-2 text-sm text-gray-800">
              <input type="radio" name="subject" value="Client" class="text-blue-600 focus:ring-blue-500">
              <span>{{#if t.contact.client}}{{t.contact.client}}{{else}}Client{{/if}}</span>
            </label>
            <label class="flex items-center space-x-2 text-sm text-gray-800">
              <input type="radio" name="subject" value="Partner" class="text-blue-600 focus:ring-blue-500">
              <span>{{#if t.contact.partner}}{{t.contact.partner}}{{else}}Partner{{/if}}</span>
            </label>
          </div>
          <input type="text" name="username" placeholder="{{#if t.contact.namePh}}{{t.contact.namePh}}{{else}}Your Name *{{/if}}"
                 class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all duration-200">
          <input type="email" name="email" placeholder="{{#if t.contact.emailPh}}{{t.contact.emailPh}}{{else}}Your Email *{{/if}}"
                 class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all duration-200">
          <input type="tel" name="phone" placeholder="{{#if t.contact.phonePh}}{{t.contact.phonePh}}{{else}}Phone number *{{/if}}"
                 class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all duration-200">
          <textarea name="message" placeholder="{{#if t.contact.messagePh}}{{t.contact.messagePh}}{{else}}Tell us about your project*{{/if}}" rows="4"
                     class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all duration-200"></textarea>
          <button type="submit"
                  class="w-full bg-blue-600 text-white font-medium px-6 py-3 rounded-full hover:bg-blue-700 transition duration-200 shadow-md transform hover:scale-105">
            {{#if t.contact.submitBtn}}{{t.contact.submitBtn}}{{else}}CONTACT US{{/if}}
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
