<section
  class="container mx-auto px-6 lg:px-12 flex flex-col lg:flex-row items-center justify-between relative overflow-hidden">
  <!-- Blue arrow shapes -->
  <div class="absolute -left-20 top-1/2 -translate-y-1/2 transform -rotate-90 hidden lg:block">
    <svg width="200" height="200" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M100 0L200 100L100 200L0 100L100 0Z" fill="#EBF8FF" stroke="#3182CE" stroke-width="2"></path>
      <path d="M100 20L180 100L100 180L20 100L100 20Z" fill="#EBF8FF" stroke="#3182CE"
            stroke-width="2"></path>
    </svg>
  </div>
  <div class="absolute -right-16 top-1/2 -translate-y-1/2 transform rotate-90 hidden lg:block">
    <svg width="100" height="100" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M50 0L100 50L50 100L0 50L50 0Z" fill="#EF4444"></path>
    </svg>
  </div>

  <!-- Left content card -->
  <div class="w-full lg:w-1/2 bg-yellow-400 rounded-3xl p-8 lg:p-12 relative shadow-2xl animate-fadeIn">
    <div class="absolute -top-6 left-8 flex space-x-2">
      <div class="w-3 h-3 bg-blue-500 rounded-full"></div>
      <div class="w-3 h-3 bg-blue-500 rounded-full"></div>
      <div class="w-3 h-3 bg-blue-500 rounded-full"></div>
    </div>
    <h1 class="text-4xl md:text-5xl font-extrabold leading-tight text-gray-800 mb-4 mt-8 drop-shadow-lg">
      {{#if (eq lang 'en')}}
        {{#if section.title}}{{section.title}}{{else}}{{#if t.hero.title}}{{t.hero.title}}{{else}}LEGO® EDUCATION<br>INSPIRES LEARNING<br>YOU CAN BUILD ON{{/if}}{{/if}}
      {{else}}
        {{#if t.hero.title}}{{t.hero.title}}{{else}}LEGO® EDUCATION INSPIRES LEARNING YOU CAN BUILD ON{{/if}}
      {{/if}}
    </h1>
    <p class="text-sm md:text-base text-gray-700 max-w-lg">
      {{#if (eq lang 'en')}}
        {{#if section.body}}{{section.body}}{{else}}{{#if t.hero.body}}{{t.hero.body}}{{else}}Learning solutions designed to empower students and teachers, build deeper understanding and engagement, and ignite a life-long love of learning.{{/if}}{{/if}}
      {{else}}
        {{#if t.hero.body}}{{t.hero.body}}{{else}}Learning solutions designed to empower students and teachers.{{/if}}
      {{/if}}
    </p>
  </div>

  <!-- Right image gallery -->
  <div class="w-full lg:w-1/2 mt-12 lg:mt-0 lg:pl-16 relative">
    <div class="grid grid-cols-2 gap-4">

      <!-- Left tall image -->
      <div class="relative row-span-2 rounded-2xl overflow-hidden shadow-xl group">
        <img src="{{#if section.imageUrl}}{{section.imageUrl}}{{else}}/images/Group%2035.png{{/if}}" alt="Elementary students learning"
             class="w-full h-full object-cover transform transition-transform duration-300 group-hover:scale-105">
        <span
          class="absolute bottom-0 left-0 w-full px-4 py-2 text-white text-lg font-semibold bg-gradient-to-t from-black/80 to-transparent">
        {{#if t.hero.elementary}}{{t.hero.elementary}}{{else}}ELEMENTARY{{/if}}
      </span>
      </div>

      <!-- Top right -->
      <div class="relative rounded-2xl overflow-hidden shadow-xl group">
        <img src="{{#if section.imageUrl2}}{{section.imageUrl2}}{{else}}/images/Group%2034.png{{/if}}" alt="Kindergarten students"
             class="w-full h-full object-cover transform transition-transform duration-300 group-hover:scale-105">
        <span
          class="absolute bottom-0 left-0 w-full px-4 py-2 text-white text-lg font-semibold bg-gradient-to-t from-black/80 to-transparent">
        {{#if t.hero.kindergarten}}{{t.hero.kindergarten}}{{else}}KINDERGARTEN{{/if}}
      </span>
      </div>

      <!-- Bottom right -->
      <div class="relative rounded-2xl overflow-hidden shadow-xl group">
        <img src="{{#if section.imageUrl3}}{{section.imageUrl3}}{{else}}/images/Mask group (3).png{{/if}}"
             alt="Middle school students"
             class="w-full h-full object-cover transform transition-transform duration-300 group-hover:scale-105">
        <span
          class="absolute bottom-0 left-0 w-full px-4 py-2 text-white text-lg font-semibold bg-gradient-to-t from-black/80 to-transparent">
        {{#if t.hero.middle}}{{t.hero.middle}}{{else}}MIDDLE{{/if}}
      </span>
      </div>

    </div>
  </div>


</section>
