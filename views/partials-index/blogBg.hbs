<section id="blog" class="py-20 px-6 lg:px-12 text-center animate-fadeIn"
         style="background-image: url('{{#if section.imageUrl}}{{section.imageUrl}}{{else}}https://cdn.britannica.com/48/182648-050-6C20C6AB/LEGO-bricks.jpg{{/if}}'); background-size: cover; background-position: center;">
  <div class="relative h-64 flex flex-col items-start justify-center p-6">
    <div class="absolute inset-0 bg-black bg-opacity-40"></div>
    <h1 class="text-white text-5xl font-bold z-10 rotated-text">
      {{#if section.title}}{{section.title}}{{else}}{{#if t.blogBg.title}}{{t.blogBg.title}}{{else}}BLOG{{/if}}{{/if}}
    </h1>
    {{#if section.subtitle}}
    <p class="text-white text-xl z-10 mt-2 opacity-90">{{section.subtitle}}</p>
    {{/if}}
  </div>
</section>
