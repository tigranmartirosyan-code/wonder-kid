<!-- Products Section -->
<section id="products" class="container mx-auto px-6 py-20 text-center animate-fadeIn"
         style="animation-delay: 1.2s;">
  <h2 class="text-3xl md:text-4xl font-extrabold text-gray-800 mb-2">
    {{#if t.product.heading1}}{{t.product.heading1}}{{else}}OUR PRODUCTS INCLUDE{{/if}}
  </h2>
  <h3 class="text-2xl md:text-3xl font-bold text-gray-800 mb-12">
    {{#if t.product.heading2}}{{t.product.heading2}}{{else}}STANDARDS-ALIGNED LESSONS{{/if}}
  </h3>

  <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
    {{#each courses}}
      <div class="bg-white rounded-xl shadow-xl transform transition-transform hover:scale-105 p-4">
        <img src="{{image}}" alt="{{title}}" class="rounded-lg w-full mb-4">
        <h4 class="font-bold text-xl mb-1">{{title}}</h4>
        <p class="text-sm text-gray-600 mb-4">{{#if ../t.product.duration}}{{../t.product.duration}}{{else}}DURATION:{{/if}} {{duration}}</p>
        <button
          class="bg-blue-600 text-white text-sm font-medium px-6 py-2 rounded-full hover:bg-blue-700 transition duration-200 shadow-md">
          {{price}}
        </button>
      </div>
    {{/each}}
  </div>
</section>