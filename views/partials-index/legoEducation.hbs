<!-- Loved by Parents Section -->
<section class="py-20 px-6 lg:px-12 text-center animate-fadeIn" style="animation-delay: 1.6s;">
  <div class="container mx-auto">
    <h2 class="text-3xl md:text-4xl font-extrabold text-gray-800 mb-12">
      {{#if section.title}}{{section.title}}{{else}}{{#if t.testimonials.title}}{{t.testimonials.title}}{{else}}LOVED BY PARENTS{{/if}}{{/if}}
    </h2>

    <div class="flex flex-wrap gap-6 justify-center">

      {{#each (parseJSON section.body)}}
      <div class="flex-1 min-w-[280px] max-w-sm bg-gray-100 rounded-2xl shadow-lg p-8 text-center">
        <span class="text-yellow-400 text-2xl">★★★★★</span>
        <p class="text-gray-700 text-base italic my-5">"{{this.quote}}"</p>
        <div class="flex items-center justify-center space-x-4">
          {{#if this.imageUrl}}
          <img src="{{this.imageUrl}}" alt="{{this.name}}" class="w-14 h-14 rounded-full border-2 border-green-500 object-cover flex-shrink-0">
          {{/if}}
          <div class="text-left">
            <h5 class="font-bold text-sm">{{this.name}}</h5>
          </div>
        </div>
      </div>
      {{else}}

      <!-- Testimonial 1 -->
      <div class="flex-1 min-w-[280px] max-w-sm bg-gray-100 rounded-2xl shadow-lg p-8 text-center">
        <span class="text-yellow-400 text-2xl">★★★★★</span>
        <p class="text-gray-700 text-base italic my-5">
          "{{#if t.testimonials.t1Quote}}{{t.testimonials.t1Quote}}{{else}}LEGO Education has changed the way I feel about teaching tremendously. When I introduced the LEGO bricks, all of a sudden, a lot of lights turned on in the classroom.{{/if}}"
        </p>
        <div class="flex items-center justify-center space-x-4">
          <div class="w-14 h-14 rounded-full border-2 border-green-500 bg-blue-200 flex items-center justify-center text-blue-700 font-bold text-lg flex-shrink-0">MY</div>
          <div class="text-left">
            <h5 class="font-bold text-sm">{{#if t.testimonials.t1Name}}{{t.testimonials.t1Name}}{{else}}MARIE YANK{{/if}}</h5>
          </div>
        </div>
      </div>

      <!-- Testimonial 2 -->
      <div class="flex-1 min-w-[280px] max-w-sm bg-gray-100 rounded-2xl shadow-lg p-8 text-center">
        <span class="text-yellow-400 text-2xl">★★★★★</span>
        <p class="text-gray-700 text-base italic my-5">
          "{{#if t.testimonials.t2Quote}}{{t.testimonials.t2Quote}}{{else}}Two of the skills that I think are super important to have in the real world are critical thinking and problem solving. Both of those skills are fostered quite easily through LEGO Education.{{/if}}"
        </p>
        <div class="flex items-center justify-center space-x-4">
          <div class="w-14 h-14 rounded-full border-2 border-red-400 bg-red-100 flex items-center justify-center text-red-600 font-bold text-lg flex-shrink-0">AM</div>
          <div class="text-left">
            <h5 class="font-bold text-sm">{{#if t.testimonials.t2Name}}{{t.testimonials.t2Name}}{{else}}ALICIA MILLER{{/if}}</h5>
          </div>
        </div>
      </div>

      <!-- Testimonial 3 -->
      <div class="flex-1 min-w-[280px] max-w-sm bg-gray-100 rounded-2xl shadow-lg p-8 text-center">
        <span class="text-yellow-400 text-2xl">★★★★★</span>
        <p class="text-gray-700 text-base italic my-5">
          "{{#if t.testimonials.t3Quote}}{{t.testimonials.t3Quote}}{{else}}The courses are fantastic! My child has learned so much and has developed a real passion for building and problem-solving.{{/if}}"
        </p>
        <div class="flex items-center justify-center space-x-4">
          <div class="w-14 h-14 rounded-full border-2 border-yellow-400 bg-yellow-100 flex items-center justify-center text-yellow-600 font-bold text-lg flex-shrink-0">JD</div>
          <div class="text-left">
            <h5 class="font-bold text-sm">{{#if t.testimonials.t3Name}}{{t.testimonials.t3Name}}{{else}}JANE DOE{{/if}}</h5>
          </div>
        </div>
      </div>

      {{/each}}
    </div>
  </div>
</section>
