<!-- Final Call to Action Section -->
<section id="contact" class="bg-yellow-400 py-20 px-6 lg:px-12 text-center animate-fadeIn"
         style="animation-delay: 2s;">
  <div class="container mx-auto">
    <h2 class="text-3xl md:text-4xl font-extrabold text-gray-800 mb-4">{{#if section.title}}{{section.title}}{{else}}{{#if t.yellowBoard.title}}{{t.yellowBoard.title}}{{else}}BRING LEGO® EDUCATION TO YOUR SCHOOL OR DISTRICT{{/if}}{{/if}}</h2>
    <a href="{{#if section.buttonLink}}{{section.buttonLink}}{{else}}#contact-form{{/if}}"
       class="inline-block bg-blue-600 text-white text-sm font-medium px-8 py-3 rounded-full hover:bg-blue-700 transition duration-200 transform hover:scale-105 shadow-md">
      {{#if section.buttonText}}{{section.buttonText}}{{else}}{{#if t.yellowBoard.btn}}{{t.yellowBoard.btn}}{{else}}CONTACT US{{/if}}{{/if}}
    </a>
  </div>
</section>