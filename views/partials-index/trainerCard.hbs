<section class="container mx-auto px-6 py-20 text-center">
  <div class="container mx-auto max-w-4xl">
    <h1 class="text-3xl md:text-4xl font-extrabold text-center text-gray-800 mb-12">TRAINERS</h1>

    {{#each trainers}}
      <div class="bg-white rounded-3xl shadow-xl flex flex-col md:flex-row items-center p-6 mb-8">
        <!-- Image Section with dynamic color -->
        <div class="relative w-full md:w-1/3 min-w-[200px] h-64 md:h-80 rounded-2xl overflow-hidden mb-6 md:mb-0 md:mr-6">
          <div class="absolute top-0 left-0 w-full h-full bg-{{color}} rounded-3xl"
               style="clip-path: polygon(0 0, 100% 0, 100% 50%, 0 100%);"></div>
          <img src="{{image}}" alt="{{fullName}}" class="absolute w-full h-full object-cover p-2 rounded-2xl">
        </div>

        <!-- Text Content -->
        <div class="md:w-2/3">
          <h2 class="text-2xl font-bold text-gray-800">{{fullName}}</h2>
          <p class="text-md text-gray-600 mb-4">{{role}}</p>
          <p class="text-gray-700 leading-relaxed mb-4">{{description}}</p>
          <button class="px-6 py-3 border-2 border-blue-500 text-blue-500 rounded-full font-semibold hover:bg-blue-500 hover:text-white transition-colors duration-300">
            ABOUT THE TRAINER
          </button>
        </div>
      </div>
    {{/each}}

  </div>
</section>