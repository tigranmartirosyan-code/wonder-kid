<section class="bg-gray-50 py-20 px-6 lg:px-12">
  <div class="container mx-auto">
    <h2 class="text-3xl md:text-4xl font-extrabold text-center text-gray-800 mb-4">{{#if section.title}}{{section.title}}{{else}}{{#if t.trainers.title}}{{t.trainers.title}}{{else}}OUR TRAINERS{{/if}}{{/if}}</h2>
    {{#if section.subtitle}}<p class="text-center text-gray-500 mb-12">{{section.subtitle}}</p>
    {{else if t.trainers.subtitle}}<p class="text-center text-gray-500 mb-12">{{t.trainers.subtitle}}</p>
    {{else}}<p class="text-center text-gray-500 mb-12">Meet our certified LEGO Education trainers</p>{{/if}}

    <div class="flex flex-wrap gap-8">
      {{#each (parseJSON section.body)}}
      <div class="flex items-center gap-6 bg-white rounded-3xl shadow-xl p-6 flex-1 min-w-[calc(50%-1rem)]">
        <div class="relative flex-shrink-0 w-40 h-48 rounded-2xl overflow-hidden">
          <div class="absolute top-0 left-0 w-full h-full bg-blue-400 rounded-3xl"
               style="clip-path: polygon(0 0, 100% 0, 100% 50%, 0 100%);"></div>
          <img src="{{this.imageUrl}}" alt="{{this.name}}" class="absolute w-full h-full object-cover p-2 rounded-2xl">
        </div>
        <div class="flex flex-col flex-1 text-left">
          <h3 class="text-xl font-bold text-gray-800 mb-1">{{this.name}}</h3>
          <p class="text-sm text-gray-500 mb-3">{{this.role}}</p>
          <p class="text-sm text-gray-600 leading-relaxed mb-4 line-clamp-4">{{this.desc}}</p>
          <div>
            <button class="px-5 py-2 border-2 border-blue-500 text-blue-500 rounded-full text-sm font-semibold hover:bg-blue-500 hover:text-white transition-colors duration-300">
              {{#if ../../t.trainers.aboutBtn}}{{../../t.trainers.aboutBtn}}{{else}}About Trainer{{/if}}
            </button>
          </div>
        </div>
      </div>
      {{else}}
      {{#each trainers}}
      <div class="flex items-center gap-6 bg-white rounded-3xl shadow-xl p-6 flex-1 min-w-[calc(50%-1rem)]">
        <div class="relative flex-shrink-0 w-40 h-48 rounded-2xl overflow-hidden">
          <div class="absolute top-0 left-0 w-full h-full bg-blue-400 rounded-3xl"
               style="clip-path: polygon(0 0, 100% 0, 100% 50%, 0 100%);"></div>
          <img src="{{image}}" alt="{{fullName}}" class="absolute w-full h-full object-cover p-2 rounded-2xl">
        </div>
        <div class="flex flex-col flex-1 text-left">
          <h3 class="text-xl font-bold text-gray-800 mb-1">
            {{#if (eq ../lang 'hy')}}{{#if fullName_hy}}{{fullName_hy}}{{else}}{{fullName}}{{/if}}
            {{else if (eq ../lang 'ru')}}{{#if fullName_ru}}{{fullName_ru}}{{else}}{{fullName}}{{/if}}
            {{else}}{{fullName}}{{/if}}
          </h3>
          <p class="text-sm text-gray-500 mb-3">
            {{#if (eq ../lang 'hy')}}{{#if role_hy}}{{role_hy}}{{else}}{{role}}{{/if}}
            {{else if (eq ../lang 'ru')}}{{#if role_ru}}{{role_ru}}{{else}}{{role}}{{/if}}
            {{else}}{{role}}{{/if}}
          </p>
          <p class="text-sm text-gray-600 leading-relaxed mb-4 line-clamp-4">
            {{#if (eq ../lang 'hy')}}{{#if description_hy}}{{description_hy}}{{else}}{{description}}{{/if}}
            {{else if (eq ../lang 'ru')}}{{#if description_ru}}{{description_ru}}{{else}}{{description}}{{/if}}
            {{else}}{{description}}{{/if}}
          </p>
          <div>
            <button class="px-5 py-2 border-2 border-blue-500 text-blue-500 rounded-full text-sm font-semibold hover:bg-blue-500 hover:text-white transition-colors duration-300">
              {{#if ../t.trainers.aboutBtn}}{{../t.trainers.aboutBtn}}{{else}}About Trainer{{/if}}
            </button>
          </div>
        </div>
      </div>
      {{/each}}
      {{/each}}
    </div>
  </div>
</section>
