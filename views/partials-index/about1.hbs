<section id="about1" class="bg-gray-100 py-20 px-6 lg:px-12 animate-fadeIn" style="animation-delay: 0.8s;">
  <div
    class="container mx-auto flex flex-col lg:flex-row items-center justify-between space-y-12 lg:space-y-0 lg:space-x-12">
    <!-- Left image -->
    <div class="w-full lg:w-1/2 relative p-4">
      <object type="image/svg+xml"
              data="{{#if section.imageUrl}}{{section.imageUrl}}{{else}}/svg/Mask%20group%20(1).svg{{/if}}"
              class="w-full h-auto">
      </object>
    </div>

    <!-- Right content -->
    <div class="w-full lg:w-1/2 text-center lg:text-left">
      <div class="flex justify-center lg:justify-start items-center space-x-2 mb-6">
        <div class="w-3 h-3 bg-yellow-400 rounded-full"></div>
        <div class="w-3 h-3 bg-yellow-400 rounded-full"></div>
        <div class="w-3 h-3 bg-yellow-400 rounded-full"></div>
        <div class="w-3 h-3 bg-yellow-400 rounded-full"></div>
      </div>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-gray-800 mb-6">{{#if section.title}}{{section.title}}{{else}}{{#if t.about1.title}}{{t.about1.title}}{{else}}LEGO WEDO 2.0{{/if}}{{/if}}</h2>
      <p class="text-xl md:text-2xl text-gray-600 leading-relaxed mb-8">
        {{#if section.body}}{{section.body}}{{else}}{{#if t.about1.body}}{{t.about1.body}}{{else}}Adobe Illustrator, Adobe Photoshop · Logo and brand identity creation · Partnering with printing houses{{/if}}{{/if}}
      </p>
      <div class="inline-block bg-yellow-200 text-black text-lg md:text-xl font-bold px-8 py-3 rounded-full shadow-md mb-8">
        {{#if section.subtitle}}{{section.subtitle}}{{else}}{{#if t.about1.price}}{{t.about1.price}}{{else}}15.000 AMD{{/if}}{{/if}}
      </div>
      <div class="flex justify-center lg:justify-start items-center space-x-4 mt-2">
        <a href="{{#if section.buttonLink}}{{section.buttonLink}}{{else}}#{{/if}}" class="bg-blue-600 text-white text-base md:text-lg font-semibold px-8 py-3 rounded-none hover:bg-blue-700 transition duration-200 transform hover:scale-105 shadow-md cursor-pointer">{{#if section.buttonText}}{{section.buttonText}}{{else}}{{#if t.about1.applyNow}}{{t.about1.applyNow}}{{else}}APPLY NOW{{/if}}{{/if}}</a>
      </div>
    </div>
  </div>
</section>
