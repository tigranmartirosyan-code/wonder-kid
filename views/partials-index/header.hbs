<!-- Fixed Header & Navigation -->
<!-- The 'fixed' and 'top-0' classes make the header stick to the top -->
<header class="fixed top-0 left-0 w-full z-50 bg-white shadow-lg p-6">
  <nav class="container mx-auto flex justify-between items-center">
    <div class="flex items-center space-x-2">
      <object type="image/svg+xml"
              data="/svg/Group 4.svg"
              class="w-full max-w-xs sm:max-w-md md:max-w-lg lg:max-w-2xl xl:max-w-4xl h-auto">
      </object>

    </div>
    <div class="hidden lg:flex items-center space-x-6">
      <a href="#products" class="text-sm font-medium hover:text-blue-600 transition duration-200">OUR COURSES</a>
      <a href="#about" class="text-sm font-medium hover:text-blue-600 transition duration-200">ABOUT US</a>
      <a href="#contact-form" class="text-sm font-medium hover:text-blue-600 transition duration-200">CONTACT
        US</a>
      <a href="#" class="text-sm font-medium hover:text-blue-600 transition duration-200">BLOG</a>
      <a href="#products"
         class="bg-blue-600 text-white text-sm font-medium px-6 py-2 rounded-full hover:bg-blue-700 transition duration-200 transform hover:scale-105 shadow-md">COURSES</a>
      <div class="flex items-center space-x-1">
        <svg class="w-4 h-4 text-gray-600" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M8 4a4 4 0 100 8a4 4 0 000-8zM2 8a6 6 10 12 0a6 6 0 00-12 0z"
                clip-rule="evenodd"></path>
        </svg>
        <span class="text-sm font-medium text-gray-600">ENG</span>
      </div>
    </div>
    <div class="lg:hidden">
      <button id="menu-btn" class="text-gray-600 focus:outline-none">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"
             xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M4 6h16M4 12h16m-7 6h7"></path>
        </svg>
      </button>
    </div>
  </nav>
  <!-- Mobile Menu -->
  <div id="nav-menu" class="hidden lg:hidden flex flex-col items-center mt-4 space-y-4">
    <a href="#products" class="text-sm font-medium hover:text-blue-600 transition duration-200">OUR COURSES</a>
    <a href="#about" class="text-sm font-medium hover:text-blue-600 transition duration-200">ABOUT US</a>
    <a href="#contact-form" class="text-sm font-medium hover:text-blue-600 transition duration-200">CONTACT US</a>
    <a href="#" class="text-sm font-medium hover:text-blue-600 transition duration-200">BLOG</a>
    <a href="#products"
       class="bg-blue-600 text-white text-sm font-medium px-6 py-2 rounded-full hover:bg-blue-700 transition duration-200 transform hover:scale-105 shadow-md">COURSES</a>
    <div class="flex items-center space-x-1">
      <svg class="w-4 h-4 text-gray-600" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M8 4a4 4 0 100 8a4 4 0 000-8zM2 8a6 6 0 1012 0a6 6 0 00-12 0z"
              clip-rule="evenodd"></path>
      </svg>
      <span class="text-sm font-medium text-gray-600">ENG</span>
    </div>
  </div>
</header>