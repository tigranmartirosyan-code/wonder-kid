{{#each sections}}
<section
  class="dynamic-section w-full"
  data-section-id="{{this.id}}"
  data-section-type="{{this.sectionType}}"
  style="background-color: {{this.backgroundColor}}; color: {{this.textColor}};"
>

  {{!-- ========== HERO ========== --}}
  {{#if (eq this.sectionType "hero")}}
  <div
    class="relative min-h-[520px] flex items-center justify-center text-center bg-cover bg-center"
    {{#if this.imageUrl}}style="background-image: linear-gradient(rgba(0,0,0,0.45), rgba(0,0,0,0.45)), url('{{this.imageUrl}}'); background-color: {{this.backgroundColor}};"{{/if}}
  >
    <div class="relative z-10 max-w-4xl mx-auto px-6 py-20">
      {{#if this.title}}
        <h1 class="text-5xl md:text-6xl font-extrabold leading-tight mb-6 drop-shadow-lg" style="color: {{this.textColor}};">
          {{this.title}}
        </h1>
      {{/if}}
      {{#if this.subtitle}}
        <p class="text-xl md:text-2xl mb-6 opacity-90 font-medium" style="color: {{this.textColor}};">
          {{this.subtitle}}
        </p>
      {{/if}}
      {{#if this.body}}
        <p class="text-base md:text-lg mb-10 opacity-80 max-w-2xl mx-auto" style="color: {{this.textColor}};">
          {{this.body}}
        </p>
      {{/if}}
      {{#if this.buttonText}}
        <a
          href="{{this.buttonLink}}"
          class="inline-block px-10 py-4 bg-yellow-400 text-gray-900 font-bold text-lg rounded-2xl shadow-xl hover:bg-yellow-300 transition-all duration-200 hover:-translate-y-1"
        >
          {{this.buttonText}}
        </a>
      {{/if}}
    </div>
  </div>

  {{!-- ========== ABOUT ========== --}}
  {{else if (eq this.sectionType "about")}}
  <div class="max-w-7xl mx-auto px-6 py-20">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div>
        {{#if this.title}}
          <h2 class="text-4xl font-extrabold mb-4 leading-tight">{{this.title}}</h2>
        {{/if}}
        {{#if this.subtitle}}
          <p class="text-xl font-medium mb-6 opacity-75">{{this.subtitle}}</p>
        {{/if}}
        {{#if this.body}}
          <p class="text-base leading-relaxed opacity-80">{{this.body}}</p>
        {{/if}}
        {{#if this.buttonText}}
          <a href="{{this.buttonLink}}" class="inline-block mt-8 px-8 py-3 rounded-xl font-bold text-white bg-indigo-600 hover:bg-indigo-700 transition-all shadow-md">
            {{this.buttonText}}
          </a>
        {{/if}}
      </div>
      {{#if this.imageUrl}}
      <div class="relative">
        <img src="{{this.imageUrl}}" alt="{{this.title}}" class="w-full h-auto rounded-3xl shadow-2xl object-cover">
      </div>
      {{/if}}
    </div>
  </div>

  {{!-- ========== FEATURES ========== --}}
  {{else if (eq this.sectionType "features")}}
  <div class="max-w-7xl mx-auto px-6 py-20">
    <div class="text-center mb-14">
      {{#if this.title}}
        <h2 class="text-4xl font-extrabold mb-4">{{this.title}}</h2>
      {{/if}}
      {{#if this.subtitle}}
        <p class="text-xl opacity-70 max-w-2xl mx-auto">{{this.subtitle}}</p>
      {{/if}}
    </div>
    {{#if this.body}}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {{!-- Render body as a prose block in a highlighted card --}}
      <div class="md:col-span-3 bg-white bg-opacity-10 rounded-2xl p-8 text-base leading-relaxed backdrop-blur-sm shadow-inner">
        {{{this.body}}}
      </div>
    </div>
    {{/if}}
  </div>

  {{!-- ========== STATS ========== --}}
  {{else if (eq this.sectionType "stats")}}
  <div class="max-w-7xl mx-auto px-6 py-16 text-center">
    {{#if this.title}}
      <h2 class="text-3xl font-extrabold mb-10">{{this.title}}</h2>
    {{/if}}
    {{#if this.body}}
    <div class="flex flex-wrap justify-center gap-8">
      <div class="bg-white bg-opacity-10 rounded-2xl px-12 py-8 shadow-lg backdrop-blur-sm min-w-[200px]">
        <div class="text-base leading-relaxed whitespace-pre-line">{{{this.body}}}</div>
      </div>
    </div>
    {{/if}}
  </div>

  {{!-- ========== CTA ========== --}}
  {{else if (eq this.sectionType "cta")}}
  <div class="py-20 px-6 text-center">
    <div class="max-w-3xl mx-auto">
      {{#if this.title}}
        <h2 class="text-4xl md:text-5xl font-extrabold mb-6">{{this.title}}</h2>
      {{/if}}
      {{#if this.subtitle}}
        <p class="text-xl mb-10 opacity-80">{{this.subtitle}}</p>
      {{/if}}
      {{#if this.buttonText}}
        <a
          href="{{this.buttonLink}}"
          class="inline-block px-12 py-5 bg-white text-gray-900 font-extrabold text-lg rounded-2xl shadow-2xl hover:shadow-xl hover:-translate-y-1 transition-all duration-200"
        >
          {{this.buttonText}}
        </a>
      {{/if}}
    </div>
  </div>

  {{!-- ========== TESTIMONIAL ========== --}}
  {{else if (eq this.sectionType "testimonial")}}
  <div class="max-w-4xl mx-auto px-6 py-20 text-center">
    {{#if this.imageUrl}}
      <img src="{{this.imageUrl}}" alt="{{this.subtitle}}" class="w-24 h-24 rounded-full object-cover mx-auto mb-6 shadow-xl border-4 border-white border-opacity-40">
    {{/if}}
    {{#if this.body}}
      <blockquote class="text-2xl md:text-3xl font-medium italic mb-8 leading-relaxed opacity-90">
        &ldquo;{{this.body}}&rdquo;
      </blockquote>
    {{/if}}
    {{#if this.title}}
      <p class="text-lg font-bold">{{this.title}}</p>
    {{/if}}
    {{#if this.subtitle}}
      <p class="text-sm opacity-70 mt-1">{{this.subtitle}}</p>
    {{/if}}
  </div>

  {{!-- ========== CUSTOM ========== --}}
  {{else if (eq this.sectionType "custom")}}
  <div class="max-w-7xl mx-auto px-6 py-16">
    {{#if this.title}}
      <h2 class="text-4xl font-extrabold mb-8 text-center">{{this.title}}</h2>
    {{/if}}
    {{#if this.body}}
      <div class="prose prose-lg max-w-none">
        {{{this.body}}}
      </div>
    {{/if}}
  </div>

  {{/if}}
</section>
{{/each}}
