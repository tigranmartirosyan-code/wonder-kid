<section id="about2" class="bg-gray-100 py-20 px-6 lg:px-12 animate-fadeIn" style="animation-delay: 0.8s;">
  <div
    class="container mx-auto flex flex-col lg:flex-row items-center justify-between space-y-12 lg:space-y-0 lg:space-x-12">
    <div class="w-full lg:w-1/2 relative">
      <object type="image/svg+xml"
              data="{{#if section.imageUrl}}{{section.imageUrl}}{{else}}/svg/Mask%20group%20(1).svg{{/if}}"
              class="w-full h-auto">
      </object>
    </div>

    <!-- Left content -->
    <div class="w-full lg:w-1/2 text-center lg:text-left">
      <div class="flex justify-center lg:justify-start items-center space-x-2 mb-4">
        <div class="w-3 h-3 bg-yellow-400 rounded-full"></div>
        <div class="w-3 h-3 bg-yellow-400 rounded-full"></div>
        <div class="w-3 h-3 bg-yellow-400 rounded-full"></div>
        <div class="w-3 h-3 bg-yellow-400 rounded-full"></div>
      </div>
      <h2 class="text-3xl md:text-4xl font-extrabold text-gray-800 mb-4">
        {{#if (eq lang 'hy')}}{{#if t.about2.title}}{{t.about2.title}}{{else}}{{#if section.title}}{{section.title}}{{else}}OUR SHORT STORY{{/if}}{{/if}}
        {{else if (eq lang 'ru')}}{{#if t.about2.title}}{{t.about2.title}}{{else}}{{#if section.title}}{{section.title}}{{else}}OUR SHORT STORY{{/if}}{{/if}}
        {{else}}{{#if section.title}}{{section.title}}{{else}}OUR SHORT STORY{{/if}}{{/if}}
      </h2>
      <p class="text-lg text-gray-600 leading-relaxed mb-6">
        {{#if (eq lang 'hy')}}{{#if t.about2.body}}{{t.about2.body}}{{else}}{{#if section.body}}{{section.body}}{{else}}By inviting joy and curiosity into the classroom, we can enable all students and educators to thrive, developing the skills needed to build a better world for themselves and for others.{{/if}}{{/if}}
        {{else if (eq lang 'ru')}}{{#if t.about2.body}}{{t.about2.body}}{{else}}{{#if section.body}}{{section.body}}{{else}}By inviting joy and curiosity into the classroom, we can enable all students and educators to thrive, developing the skills needed to build a better world for themselves and for others.{{/if}}{{/if}}
        {{else}}{{#if section.body}}{{section.body}}{{else}}By inviting joy and curiosity into the classroom, we can enable all students and educators to thrive, developing the skills needed to build a better world for themselves and for others.{{/if}}{{/if}}
      </p>
      <a href="{{#if section.buttonLink}}{{section.buttonLink}}{{else}}#{{/if}}"
         class="inline-flex items-center text-lg font-semibold text-blue-600 hover:text-blue-800 transition duration-200">
        {{#if (eq lang 'hy')}}{{#if t.about2.readMore}}{{t.about2.readMore}}{{else}}{{#if section.buttonText}}{{section.buttonText}}{{else}}READ MORE{{/if}}{{/if}}
        {{else if (eq lang 'ru')}}{{#if t.about2.readMore}}{{t.about2.readMore}}{{else}}{{#if section.buttonText}}{{section.buttonText}}{{else}}READ MORE{{/if}}{{/if}}
        {{else}}{{#if section.buttonText}}{{section.buttonText}}{{else}}READ MORE{{/if}}{{/if}}
        <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"
             xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      </a>
    </div>

    <!-- Right image grid -->

  </div>
</section>