<section id="students-content" class="hidden">
  <header class="flex items-center justify-between mb-8">
    <h2 class="text-3xl font-bold text-gray-900">Students Management</h2>
  </header>
  <div class="bg-white rounded-xl shadow-md p-6">
    <div class="mb-12">
      <h2 class="text-2xl font-bold text-gray-800 mb-4">Students</h2>
      <div class="overflow-x-auto bg-white rounded-xl shadow-lg">
        <table class="min-w-full rounded-xl overflow-hidden">
          <thead class="text-gray-700">
          <tr>
            <th class="px-4 py-2 rounded-tl-xl text-left">Image</th>
            <th class="px-4 py-2 text-left">Full Name</th>
            <th class="px-4 py-2 text-left">Email</th>
            <th class="px-4 py-2 text-left">Age</th>
            <th class="px-4 py-2 text-left">Group Name</th>
            <th class="px-4 py-2 text-left">Phones</th>
            <th class="px-4 py-2 text-left">Schedule</th>
            <th class="px-4 py-2 rounded-tr-xl text-left">Actions</th>
          </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
          {{#each students}}
            <tr>
              <td class="px-4 py-2">
                <img src="{{ image }}" alt="Student Image" class="rounded-full w-16 h-16">
              </td>
              <td class="px-4 py-2">{{fullName}}</td>
              <td class="px-4 py-2">{{email}}</td>
              <td class="px-4 py-2">{{age}}</td>
              <td class="px-4 py-2">{{groupName}}</td>
              <td class="px-4 py-2">{{phones}}</td>
              <td class="px-4 py-2">
                {{#each schedules}}
                  {{title}}{{#unless @last}}, {{/unless}}
                {{/each}}
              </td>
              <td class="px-4 py-2">
                <button data-id="{{id}}" data-type="students"
                        class="edit-btn px-3 py-1 bg-blue-500 text-white rounded-lg hover:bg-blue-600"><i class="fas fa-edit"></i>
                </button>
                <button data-id="{{id}}" data-type="students"
                        class="delete-btn px-3 py-1 bg-red-500 text-white rounded-lg hover:bg-red-600"><i class="fas fa-trash"></i>
                </button>
              </td>
            </tr>
          {{/each}}
          </tbody>
        </table>
      </div>
    </div>
    <div class="mt-8 bg-gray-50 p-6 rounded-xl shadow-md">
      <h3 class="text-xl font-bold mb-4 text-gray-800">Add / Edit Student</h3>
      <form id="studentForm" action="/students" method="POST" class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="md:col-span-1">
          <label for="fullName" class="block text-sm font-medium text-gray-700 mb-1">Full Name</label>
          <input type="text" id="fullName" name="fullName" placeholder="Full Name" required class="form-input w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500 transition duration-300">
        </div>
        <div class="md:col-span-1">
          <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
          <input type="email" id="email" name="email" placeholder="Email" class="form-input w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500 transition duration-300">
        </div>
        <div class="md:col-span-1">
          <label for="age" class="block text-sm font-medium text-gray-700 mb-1">Age</label>
          <input type="number" id="age" name="age" placeholder="Age" class="form-input w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500 transition duration-300">
        </div>
        <div class="md:col-span-1">
          <label for="groupName" class="block text-sm font-medium text-gray-700 mb-1">Group Name</label>
          <input type="text" id="groupName" name="groupName" placeholder="Group Name" class="form-input w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500 transition duration-300">
        </div>
        <div class="md:col-span-2">
          <label for="phones" class="block text-sm font-medium text-gray-700 mb-1">Phones (comma separated)</label>
          <input type="text" id="phones" name="phones" placeholder="Phones (comma separated)" class="form-input w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500 transition duration-300">
        </div>

        <button type="submit"
                class="col-span-2 py-3 px-4 rounded-full font-semibold text-white bg-indigo-600 hover:bg-indigo-700 transition duration-300 shadow-md">
          Save Student
        </button>
      </form>

    </div>
  </div>
</section>