    //       }
    //     ],
    //     "students": [
    //       {
    //         "fullName": "Olivia Brown",
    //         "email": "olivia.brown@example.com",
    //         "age": 42,
    //         "groupName": "Core Crew",
    //         "phones": "+1-555-0103"
    //       }
    //     ]
    //   },
    //   {
    //     "id": "4",
    //     "title": "Weekend Workout",
    //     "startDate": "2025-09-13T10:00:00Z",
    //     "endDate": "2025-09-14T12:00:00Z",
    //     "color": "#F59E0B",
    //     "trainers": [
    //       {
    //         "fullName": "David Lee",
    //         "role": "Strength Coach",
    //         "image": "https://placehold.co/100x100/FDE68A/B45309?text=DL",
    //         "description": "David specializes in weight training and circuit exercises."
    //       }
    //     ],
    //     "students": []
    //   }
    // ];
    let schedules;

    async function fetchSchedules() {
      try {
        const response = await fetch('http://localhost:3000/schedules');
        if (!response.ok) throw new Error('Network response was not ok');

        schedules = await response.json();
        renderCalendar()
      } catch (error) {
        console.error('Error fetching schedules:', error);
      }
    }

    (async function loadSchedules() {
      await fetchSchedules();
    })()

    function renderCalendar() {
      monthGrid.innerHTML = '';
      const year = currentMonth.getFullYear();
      const month = currentMonth.getMonth();

      const firstDayOfMonth = new Date(year, month, 1);
      const lastDayOfMonth = new Date(year, month + 1, 0);
      const daysInMonth = lastDayOfMonth.getDate();
      const startDayOfWeek = firstDayOfMonth.getDay(); // 0 = Sunday, 1 = Monday, etc.

      // Update month title
      monthTitle.textContent = `${currentMonth.toLocaleString('default', { month: 'long' })} ${year}`;

      // Add empty cells for the days before the 1st
      for (let i = 0; i < startDayOfWeek; i++) {
        const emptyCell = document.createElement('div');
        emptyCell.className = 'day-cell bg-gray-100';
        monthGrid.appendChild(emptyCell);
      }

      // Render days of the month
      for (let i = 1; i <= daysInMonth; i++) {
        const dayCell = document.createElement('div');
        dayCell.className = 'day-cell';

        const dayNumber = document.createElement('div');
        dayNumber.className = 'font-bold text-lg text-gray-800';
        dayNumber.textContent = i;
        dayCell.appendChild(dayNumber);

        // Check if the current day is Sunday (getDay() returns 0 for Sunday)
        const currentDay = new Date(year, month, i);
        if (currentDay.getDay() === 0) {
          // If it's Sunday, skip adding event slots
          monthGrid.appendChild(dayCell);
          continue;
        }

        // Add events for this day
        schedules.forEach(event => {
          const eventStart = new Date(event.startDate);
          const eventEnd = new Date(event.endDate);

          // Normalize dates to midnight for accurate comparison, regardless of timezones
          const dayToCheck = new Date(currentDay.getFullYear(), currentDay.getMonth(), currentDay.getDate());
          const eventStartDay = new Date(eventStart.getFullYear(), eventStart.getMonth(), eventStart.getDate());
          const eventEndDay = new Date(eventEnd.getFullYear(), eventEnd.getMonth(), eventEnd.getDate());

          if (dayToCheck.getTime() >= eventStartDay.getTime() && dayToCheck.getTime() <= eventEndDay.getTime()) {
            const eventDiv = document.createElement('div');
            eventDiv.className = 'event-card';
            eventDiv.textContent = event.title;
            eventDiv.style.backgroundColor = `${event.color}20`;
            eventDiv.style.color = event.color;
            eventDiv.style.borderColor = event.color;
            eventDiv.style.borderLeftColor = event.color;
            eventDiv.setAttribute('data-event-id', event.id); // Add a data attribute to link the div to its data
            dayCell.appendChild(eventDiv);
          }
        });

        monthGrid.appendChild(dayCell);
      }
    }

    // Show the modal with specific event data
    function showModal(eventData) {
      document.getElementById('modal-title').textContent = eventData.title;

      const eventStart = new Date(eventData.startDate);
      const eventEnd = new Date(eventData.endDate);
      const options = { weekday: 'short', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' };
      const startString = eventStart.toLocaleDateString('en-US', options);
      const endString = eventEnd.toLocaleDateString('en-US', options);
      modalTime.textContent = `${startString} - ${endString}`;

      // Clear previous content
      trainerDetailsContainer.innerHTML = '<h4 class="text-lg font-semibold text-blue-600">Trainer Details</h4>';
      studentDetailsContainer.innerHTML = '<h4 class="text-lg font-semibold text-green-600">Student Details</h4>';

      // Dynamically create and append trainer details
      eventData.trainers.forEach(trainer => {
        const trainerHtml = `
          <div class="flex items-center space-x-4 bg-gray-50 p-4 rounded-lg shadow-inner">
            <img src="${trainer.image}" alt="Trainer Profile" class="w-16 h-16 rounded-full object-cover border-2 border-gray-300">
            <div>
              <h4 class="text-lg font-semibold text-blue-600">${trainer.fullName}</h4>
              <p class="text-sm text-gray-500">${trainer.role}</p>
              <p class="text-xs text-gray-400">${trainer.description}</p>
            </div>
          </div>
        `;
        trainerDetailsContainer.insertAdjacentHTML('beforeend', trainerHtml);
      });

      // Dynamically create and append student details
      eventData.students.forEach(student => {
        const studentHtml = `
          <div class="bg-gray-50 p-4 rounded-lg shadow-inner">
            <div class="space-y-1 text-sm text-gray-700">
              <p><span class="font-medium">Name:</span> <span>${student.fullName}</span></p>
              <p><span class="font-medium">Email:</span> <span>${student.email}</span></p>
              <p><span class="font-medium">Age:</span> <span>${student.age}</span></p>
              <p><span class="font-medium">Group:</span> <span>${student.groupName}</span></p>
              <p><span class="font-medium">Phone:</span> <span>${student.phones}</span></p>
            </div>
          </div>
        `;
        studentDetailsContainer.insertAdjacentHTML('beforeend', studentHtml);
      });

      eventModal.style.display = 'flex';
    }

    // Hide the modal
    function hideModal() {
      eventModal.style.display = 'none';
    }

    // Event listener for calendar grid clicks
    monthGrid.addEventListener('click', (event) => {
      const eventCard = event.target.closest('.event-card');
      if (eventCard) {
        const eventId = eventCard.getAttribute('data-event-id');
        const eventData = schedules.find(s => s.id === eventId);
        if (eventData) {
          showModal(eventData);
        }
      }
    });

    // Event listener to close the modal
    closeModalBtn.addEventListener('click', hideModal);

    // Close modal if user clicks outside of the content
    window.addEventListener('click', (event) => {
      if (event.target === eventModal) {
        hideModal();
      }
    });

    prevMonthBtn.addEventListener('click', () => {
      currentMonth.setMonth(currentMonth.getMonth() - 1);
      renderCalendar();
    });

    nextMonthBtn.addEventListener('click', () => {
      currentMonth.setMonth(currentMonth.getMonth() + 1);
      renderCalendar();
    });

    // Initial render of the calendar with the provided data
    renderCalendar();
  });
</script>

</html>
