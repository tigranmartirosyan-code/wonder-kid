<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Monthly Schedule Board</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&display=swap" rel="stylesheet">
  <style>
    .calendar-grid {
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      gap: 1px;
      background-color:  rgb(234 179 8 / var(--tw-bg-opacity, 1));
      border-radius: 0.75rem;
      overflow: hidden;
      border: 1px solid #e5e7eb;
    }
    .day-cell {
      min-height: 120px;
      background-color: #ffffff;
      padding: 0.5rem;
      position: relative;
    }
    .event-card {
      color: black;
      background-color:  rgb(234 179 8 / var(--tw-bg-opacity, 1));
      font-size: 0.875rem;
      border-radius: 0.5rem;
      padding: 0.25rem 0.5rem;
      margin-bottom: 0.25rem;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      border-left-width: 4px;
      font-weight: 500;
      cursor: pointer;
      transition: transform 0.1s ease-in-out;
    }
    .event-card:hover {
      transform: translateY(-2px);
    }
    /* Modal styles */
    .modal {
      display: none;
      position: fixed;
      z-index: 100;
      left: 0;
      top: 0;
      width: 100%;
      height: 100%;
      background-color: rgba(0, 0, 0, 0.5);
      justify-content: center;
      align-items: center;
    }
    .modal-content {
      background-color: #fefefe;
      padding: 2rem;
      border-radius: 1rem;
      width: 90%;
      max-width: 500px;
      position: relative;
      box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
    }
  </style>
</head>

<div class="calendar-container">
  <div class=" mb-6">
    <h3 class="text-3xl font-bold text-red-800">Monthly Schedule Board</h3>
  </div>

  <!-- Calendar Header -->
  <div class="flex justify-between items-center mb-4">
    <button id="prev-month" class="p-2 rounded-full hover:bg-gray-200 transition-colors duration-200">
      <svg class="w-6 h-6 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
    </button>
    <h4 id="month-title" class="text-xl font-semibold text-gray-700"></h4>
    <button id="next-month" class="p-2 rounded-full hover:bg-gray-200 transition-colors duration-200">
      <svg class="w-6 h-6 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
    </button>
  </div>

  <!-- Days of the Week Header -->
  <div class="calendar-grid text-center font-bold text-gray-600 mb-1 rounded-none">
    <div class="p-2">Sun</div>
    <div class="p-2">Mon</div>
    <div class="p-2">Tue</div>
    <div class="p-2">Wed</div>
    <div class="p-2">Thu</div>
    <div class="p-2">Fri</div>
    <div class="p-2">Sat</div>
  </div>

  <!-- Calendar Grid -->
  <div id="month-grid" class="calendar-grid">
    <!-- Day cells and events will be rendered here -->
  </div>
</div>

<!-- Modal for displaying event details -->
<div id="event-modal" class="modal">
  <div class="modal-content text-gray-800">
    <button id="close-modal" class="absolute top-4 right-4 text-gray-400 hover:text-gray-600 transition-colors duration-200">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
    </button>

    <h3 id="modal-title" class="text-2xl font-bold mb-4 text-center"></h3>
    <p id="modal-time" class="text-md text-gray-500 text-center mb-4"></p>

    <div class="space-y-6">
      <!-- Trainer Details Section -->
      <div id="trainer-details-container" class="space-y-4">
        <h4 class="text-lg font-semibold text-blue-600">Trainer Details</h4>
        <!-- Trainers will be injected here -->
      </div>

      <!-- Student Details Section -->
      <div id="student-details-container" class="space-y-4">
        <h4 class="text-lg font-semibold text-green-600">Student Details</h4>
        <!-- Students will be injected here -->
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const monthGrid = document.getElementById('month-grid');
    const monthTitle = document.getElementById('month-title');
    const prevMonthBtn = document.getElementById('prev-month');
    const nextMonthBtn = document.getElementById('next-month');
    const eventModal = document.getElementById('event-modal');
    const closeModalBtn = document.getElementById('close-modal');
    const trainerDetailsContainer = document.getElementById('trainer-details-container');
    const studentDetailsContainer = document.getElementById('student-details-container');
    const modalTime = document.getElementById('modal-time');

    let currentMonth = new Date();

    // Mock data for events, now with start and end dates
    // let schedules = [
