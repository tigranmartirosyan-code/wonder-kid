    <form id="landing-section-form" class="flex-1 overflow-y-auto">
      <input type="hidden" id="ls-section-id" name="id" value="">

      <!-- Section Type Bar -->
      <div class="bg-gray-50 border-b border-gray-100 px-6 py-3">
        <div class="flex items-center gap-3">
          <label class="text-xs font-bold text-gray-500 uppercase tracking-wider whitespace-nowrap">Section Type</label>
          <select id="ls-section-type" name="sectionType" required
                  class="flex-1 px-3 py-2 border border-gray-200 rounded-xl bg-white text-gray-800 font-semibold text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
            <option value="hero">🖼  Hero — Full-width banner with headline &amp; CTA</option>
            <option value="about">ℹ️  About — Text &amp; image side by side</option>
            <option value="features">✅  Features — Highlight key features</option>
            <option value="stats">📊  Stats — Numbers and achievements</option>
            <option value="cta">📣  Call to Action — Drive conversions</option>
            <option value="testimonial">💬  Testimonial — Quote and author</option>
            <option value="custom">⚙️  Custom — Free HTML content</option>
          </select>
        </div>
      </div>

      <!-- Two-Column Body -->
      <div class="grid grid-cols-5 divide-x divide-gray-100 min-h-0">

        <!-- ── LEFT: Content Fields (3/5) ── -->
        <div class="col-span-3 px-6 py-5 space-y-5 overflow-y-auto">

          <!-- Title -->
          <div>
            <label class="flex items-center gap-1.5 text-xs font-bold text-gray-500 uppercase tracking-wider mb-2">
              <i class="fas fa-heading text-gray-300"></i>
              <span id="ls-title-label">Title</span>
            </label>
            <input type="text" id="ls-title" name="title"
                   class="w-full px-4 py-3 border border-gray-200 rounded-xl text-gray-900 font-semibold text-base focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 placeholder-gray-300 transition-all"
                   placeholder="Enter section title…">
          </div>

          <!-- Subtitle -->
          <div id="ls-field-subtitle">
            <label class="flex items-center gap-1.5 text-xs font-bold text-gray-500 uppercase tracking-wider mb-2">
              <i class="fas fa-text-height text-gray-300"></i>
              <span id="ls-subtitle-label">Subtitle</span>
            </label>
            <input type="text" id="ls-subtitle" name="subtitle"
                   class="w-full px-4 py-3 border border-gray-200 rounded-xl text-gray-800 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 placeholder-gray-300 transition-all"
                   placeholder="Supporting text or subtitle…">
          </div>

          <!-- Body -->
          <div id="ls-field-body">
            <label class="flex items-center gap-1.5 text-xs font-bold text-gray-500 uppercase tracking-wider mb-2">
              <i class="fas fa-align-left text-gray-300"></i>
              <span id="ls-body-label">Content</span>
            </label>
            <textarea id="ls-body" name="body" rows="7"
                      class="w-full px-4 py-3 border border-gray-200 rounded-xl text-gray-800 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 placeholder-gray-300 resize-y transition-all font-mono leading-relaxed"
                      placeholder="Enter content…"></textarea>
            <p id="ls-body-hint" class="text-xs text-gray-400 mt-1.5 flex items-center gap-1">
              <i class="fas fa-info-circle"></i> Plain text. Line breaks supported.
            </p>
          </div>

          <!-- Button CTA -->
          <div id="ls-field-button">
            <label class="flex items-center gap-1.5 text-xs font-bold text-gray-500 uppercase tracking-wider mb-2">
              <i class="fas fa-hand-pointer text-gray-300"></i> Call to Action Button
            </label>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <input type="text" id="ls-buttonText" name="buttonText"
                       class="w-full px-4 py-3 border border-gray-200 rounded-xl text-gray-800 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 placeholder-gray-300 transition-all"
                       placeholder="Button label…">
                <p class="text-xs text-gray-400 mt-1">Button text</p>
              </div>
              <div>
                <input type="text" id="ls-buttonLink" name="buttonLink"
                       class="w-full px-4 py-3 border border-gray-200 rounded-xl text-gray-800 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 placeholder-gray-300 transition-all"
                       placeholder="/contact">
                <p class="text-xs text-gray-400 mt-1">Link URL</p>
              </div>
            </div>
          </div>

        </div>

        <!-- ── RIGHT: Media & Style (2/5) ── -->
        <div class="col-span-2 px-5 py-5 space-y-5 bg-gray-50 overflow-y-auto">

          <!-- Image Upload -->
          <div id="ls-field-image">
            <label class="flex items-center gap-1.5 text-xs font-bold text-gray-500 uppercase tracking-wider mb-2">
              <i class="fas fa-image text-gray-300"></i>
              <span id="ls-image-label">Image</span>
            </label>

            <!-- Drop zone -->
            <div id="ls-drop-zone"
                 class="relative border-2 border-dashed border-gray-200 rounded-2xl bg-white hover:border-indigo-400 hover:bg-indigo-50 transition-all cursor-pointer group overflow-hidden"
                 style="min-height:140px;">
              <!-- Preview (hidden by default) -->
              <div id="ls-image-preview-wrap" class="hidden absolute inset-0">
                <img id="ls-image-preview" src="" alt="" class="w-full h-full object-cover">
                <div class="absolute inset-0 bg-black bg-opacity-40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                  <span class="text-white text-xs font-semibold bg-black bg-opacity-60 px-3 py-1.5 rounded-lg">
                    <i class="fas fa-camera mr-1"></i> Change Image
                  </span>
                </div>
              </div>
              <!-- Upload placeholder -->
              <div id="ls-drop-placeholder" class="flex flex-col items-center justify-center py-8 px-4 text-center">
                <div class="w-12 h-12 rounded-xl bg-indigo-50 flex items-center justify-center mb-3 group-hover:bg-indigo-100 transition-all">
                  <i class="fas fa-cloud-upload-alt text-indigo-400 text-xl"></i>
                </div>
                <p class="text-sm font-semibold text-gray-600 mb-0.5">Drop image here</p>
                <p class="text-xs text-gray-400">or click to browse</p>
                <p class="text-xs text-gray-300 mt-1">PNG, JPG, WEBP up to 10MB</p>
              </div>
              <!-- Hidden file input -->
              <input type="file" id="ls-image-file" accept="image/*" class="absolute inset-0 opacity-0 cursor-pointer w-full h-full">
            </div>

            <!-- Upload progress -->
            <div id="ls-upload-progress" class="hidden mt-2 flex items-center gap-2 text-xs text-indigo-600">
              <i class="fas fa-spinner fa-spin"></i> Uploading…
            </div>

            <!-- URL input fallback -->
            <div class="mt-2">
              <div class="flex items-center gap-2">
                <i class="fas fa-link text-gray-300 text-xs flex-shrink-0"></i>
                <input type="text" id="ls-imageUrl" name="imageUrl"
                       class="flex-1 px-3 py-2 border border-gray-200 rounded-xl text-xs text-gray-600 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 placeholder-gray-300 bg-white transition-all"
                       placeholder="Or paste image URL…">
              </div>
            </div>
          </div>

          <!-- Colors -->
          <div>
            <label class="flex items-center gap-1.5 text-xs font-bold text-gray-500 uppercase tracking-wider mb-2">
              <i class="fas fa-palette text-gray-300"></i> Colors
            </label>
            <!-- Live preview card -->
            <div id="ls-color-preview" class="rounded-xl p-4 mb-3 border border-gray-200 transition-all" style="background:#1e3a5f;">
              <p class="text-xs font-bold mb-0.5" id="ls-color-preview-title" style="color:#ffffff;">Section Title</p>
              <p class="text-xs opacity-75" id="ls-color-preview-sub" style="color:#ffffff;">Subtitle text preview</p>
            </div>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="text-xs text-gray-500 font-semibold mb-1 block">Background</label>
                <div class="flex items-center gap-2 border border-gray-200 rounded-xl px-2 py-1.5 bg-white">
                  <input type="color" id="ls-backgroundColor" name="backgroundColor" value="#1e3a5f"
                         class="w-7 h-7 rounded-lg border-0 cursor-pointer flex-shrink-0 p-0">
                  <input type="text" id="ls-bg-hex" maxlength="7"
                         class="flex-1 text-xs font-mono text-gray-700 border-0 outline-none bg-transparent w-0 min-w-0"
                         placeholder="#1e3a5f">
                </div>
              </div>
              <div>
                <label class="text-xs text-gray-500 font-semibold mb-1 block">Text Color</label>
                <div class="flex items-center gap-2 border border-gray-200 rounded-xl px-2 py-1.5 bg-white">
                  <input type="color" id="ls-textColor" name="textColor" value="#ffffff"
                         class="w-7 h-7 rounded-lg border-0 cursor-pointer flex-shrink-0 p-0">
                  <input type="text" id="ls-text-hex" maxlength="7"
                         class="flex-1 text-xs font-mono text-gray-700 border-0 outline-none bg-transparent w-0 min-w-0"
                         placeholder="#ffffff">
                </div>
              </div>
            </div>
          </div>

          <!-- Settings -->
          <div>
            <label class="flex items-center gap-1.5 text-xs font-bold text-gray-500 uppercase tracking-wider mb-2">
              <i class="fas fa-cog text-gray-300"></i> Settings
            </label>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="text-xs text-gray-500 font-semibold mb-1 block">Sort Order</label>
                <input type="number" id="ls-sortOrder" name="sortOrder" value="0" min="0"
                       class="w-full px-3 py-2.5 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-indigo-500 bg-white transition-all">
              </div>
              <div>
                <label class="text-xs text-gray-500 font-semibold mb-1 block">Visibility</label>
                <div class="flex items-center gap-2 border border-gray-200 rounded-xl px-3 py-2.5 bg-white">
                  <label class="relative inline-flex items-center cursor-pointer">
                    <input type="checkbox" id="ls-isVisible" name="isVisible" checked class="sr-only peer">
                    <div class="w-10 h-5 bg-gray-200 rounded-full peer peer-checked:after:translate-x-5 peer-checked:after:border-white after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-indigo-600"></div>
                  </label>
                  <span class="text-sm font-semibold text-gray-700" id="ls-visible-label">On</span>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>

      <!-- ── Footer ── -->
      <div class="flex items-center justify-between px-6 py-4 border-t border-gray-100 bg-white flex-shrink-0">
        <div id="ls-builtin-badge" class="hidden items-center gap-2 text-xs text-indigo-600 font-semibold bg-indigo-50 px-3 py-1.5 rounded-lg">
          <i class="fas fa-link text-xs"></i>
          <span>Linked to built-in section</span>
        </div>
        <div class="flex-1"></div>
        <div class="flex gap-3">
          <button type="button" id="ls-modal-cancel"
                  class="px-5 py-2.5 text-sm font-semibold text-gray-600 bg-gray-100 rounded-xl hover:bg-gray-200 transition-all">
            Cancel
          </button>
          <button type="submit"
                  class="px-7 py-2.5 text-sm font-bold text-white bg-indigo-600 rounded-xl hover:bg-indigo-700 transition-all shadow-lg shadow-indigo-200 flex items-center gap-2">
            <i class="fas fa-save"></i>
            <span id="ls-submit-label">Save Section</span>
          </button>
        </div>
      </div>

    </form>
  </div>
</div>
