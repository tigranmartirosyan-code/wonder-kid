<section id="schedules-content" class="hidden">
  <header class="flex items-center justify-between mb-8">
    <h2 class="text-3xl font-bold text-gray-900">Schedules Management</h2>
    {{#if isAdmin}}
    <button class="add-btn flex items-center px-5 py-2.5 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition-all duration-200 shadow-md hover:shadow-lg"
            data-type="schedules">
      <i class="fas fa-plus mr-2"></i> Add Schedule
    </button>
    {{/if}}
  </header>

  <div class="overflow-x-auto bg-white rounded-xl shadow-lg">
    <table class="min-w-full rounded-xl overflow-hidden">
      <thead class="text-gray-700">
      <tr>
        <th class="px-4 py-2 rounded-tl-xl text-left">Students</th>
        <th class="px-4 py-2 text-left">Trainers</th>
        <th class="px-4 py-2 text-left">Title</th>
        <th class="px-4 py-2 text-left">Dates</th>
        <th class="px-4 py-2 text-left">Color</th>
        {{#if isAdmin}}<th class="px-4 py-2 rounded-tr-xl text-left">Actions</th>{{/if}}
      </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
      {{#each schedules}}
        <tr>
          <!-- Students -->
          <td class="px-4 py-2 align-top">
            <ul class="space-y-2 max-h-32 overflow-y-auto pr-1">
              {{#each students}}
                <li class="flex items-center space-x-2">
                  <img src="{{image}}" alt="{{fullName}}" class="h-8 w-8 rounded-full object-cover border">
                  <span class="text-sm font-medium text-gray-800">{{fullName}}</span>
                </li>
              {{/each}}
            </ul>
          </td>

          <!-- Trainers -->
          <td class="px-4 py-2 align-top">
            <ul class="space-y-2 max-h-32 overflow-y-auto pr-1">
              {{#each trainers}}
                <li class="flex items-center space-x-2">
                  <img src="{{image}}" alt="{{fullName}}" class="h-8 w-8 rounded-full object-cover border">
                  <span class="text-sm font-medium text-gray-800">{{fullName}}</span>
                  <span class="text-xs text-gray-500">({{role}})</span>
                </li>
              {{/each}}
            </ul>
          </td>

          <!-- Title -->
          <td class="px-4 py-2 font-semibold">{{title}}</td>

          <!-- Dates -->
          <td class="px-4 py-2 text-sm whitespace-nowrap">
            {{formatDate startDate "MMM D, YYYY"}} → {{formatDate endDate "MMM D, YYYY"}}
          </td>

          <!-- Color -->
          <td class="px-4 py-2">
            <span class="px-3 py-1 rounded-lg text-white text-xs font-semibold shadow-sm"
                  style="background-color: {{color}};">
              {{color}}
            </span>
          </td>

          <!-- Actions -->
          {{#if ../isAdmin}}
          <td class="px-4 py-2">
            <button data-id="{{id}}" data-type="schedules"
                    class="edit-btn px-3 py-1 bg-blue-500 text-white rounded-lg hover:bg-blue-600">
              <i class="fas fa-edit"></i>
            </button>
            <button data-id="{{id}}" data-type="schedules"
                    class="delete-btn px-3 py-1 bg-red-500 text-white rounded-lg hover:bg-red-600">
              <i class="fas fa-trash"></i>
            </button>
          </td>
          {{/if}}
        </tr>
      {{/each}}
      </tbody>
    </table>
  </div>
</section>
