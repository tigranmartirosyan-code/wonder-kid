<section id="courses-content" class="hidden">
  <header class="flex items-center justify-between mb-4">
    <h2 class="text-3xl font-bold text-gray-900">Courses Management</h2>
    {{#if isAdmin}}
    <button class="add-btn flex items-center px-5 py-2.5 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition-all duration-200 shadow-md hover:shadow-lg"
            data-type="courses">
      <i class="fas fa-plus mr-2"></i> Add Course
    </button>
    {{/if}}
  </header>
  <hr class="border-black mb-4">

  <div class="flex flex-wrap items-center justify-between gap-3 mb-4">
    <div class="flex flex-wrap items-center gap-3">
      <select class="table-filter border border-gray-300 rounded-lg px-4 py-2 text-sm bg-white text-gray-700 font-medium focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 appearance-none cursor-pointer" data-table="courses-table" data-filter-key="duration">
        <option value="">All Durations</option>
      </select>
      <select class="table-filter border border-gray-300 rounded-lg px-4 py-2 text-sm bg-white text-gray-700 font-medium focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 appearance-none cursor-pointer" data-table="courses-table" data-filter-key="price">
        <option value="">All Prices</option>
      </select>
      <select class="table-page-size border border-gray-300 rounded-lg px-4 py-2 text-sm bg-white text-gray-700 font-medium focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 appearance-none cursor-pointer" data-table="courses-table">
        <option value="10">10 / page</option>
        <option value="25">25 / page</option>
        <option value="50">50 / page</option>
        <option value="100">100 / page</option>
      </select>
    </div>
    <div class="relative min-w-[300px] max-w-md">
      <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm"></i>
      <input type="text" placeholder="Search courses..." class="table-search w-full pl-9 pr-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" data-table="courses-table">
    </div>
  </div>


  <div class="overflow-x-auto bg-white rounded-xl shadow-lg">
    <table id="courses-table" class="min-w-full rounded-xl overflow-hidden">
      <thead class="text-gray-700">
      <tr>
        <th class="px-4 py-2 rounded-tl-xl text-left">Image</th>
        <th class="px-4 py-2 text-left">Title</th>
        <th class="px-4 py-2 text-left">Duration</th>
        <th class="px-4 py-2 text-left">Price</th>
        {{#if isAdmin}}<th class="px-4 py-2 rounded-tr-xl text-left">Actions</th>{{/if}}
      </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
      </tbody>
    </table>
  </div>
  <div class="table-pagination flex items-center justify-between mt-4 text-sm text-gray-600" data-table="courses-table">
    <span class="pagination-info"></span>
    <div class="flex items-center gap-1">
      <button class="pagination-prev px-3 py-1 border border-gray-300 rounded-lg hover:bg-gray-100 disabled:opacity-50 disabled:cursor-not-allowed">Prev</button>
      <span class="pagination-pages flex gap-1"></span>
      <button class="pagination-next px-3 py-1 border border-gray-300 rounded-lg hover:bg-gray-100 disabled:opacity-50 disabled:cursor-not-allowed">Next</button>
    </div>
  </div>
</section>